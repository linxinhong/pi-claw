{
	"name": "@linxinhong/pi-claw",
	"version": "1.0.0",
	"description": "Multi-platform bot gateway with plugin architecture",
	"type": "module",
	"main": "dist/main.js",
	"types": "dist/main.d.ts",
	"bin": {
		"pi-claw": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsc && cp -r templates dist/ && cp -r docs dist/ && cp pnpm-lock.yaml dist/ && cp -r scripts dist/ && sed 's|dist/main.js|main.js|g; s|dist/main.d.ts|main.d.ts|g; s|./dist/cli.js|./cli.js|g' package.json > dist/package.json",
		"start": "node dist/main.js",
		"dev": "tsx src/main.ts",
		"typecheck": "tsc --noEmit",
		"init": "tsx scripts/init-workspace.ts",
		"lock": "bash scripts/lock-config.sh lock",
		"unlock": "bash scripts/lock-config.sh unlock",
		"config:status": "bash scripts/lock-config.sh status",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:unit": "vitest run tests/unit",
		"test:watch": "vitest watch"
	},
	"dependencies": {
		"@larksuiteoapi/node-sdk": "^1.29.0",
		"@mariozechner/pi-agent-core": "^0.55.3",
		"@mariozechner/pi-ai": "^0.55.3",
		"@mariozechner/pi-coding-agent": "^0.55.3",
		"@sinclair/typebox": "^0.34.48",
		"better-sqlite3": "^11.0.0",
		"commander": "^12.0.0",
		"croner": "^8.0.0",
		"express": "^4.18.2",
		"node-llama-cpp": "^3.0.0",
		"openai": "^4.0.0",
		"sqlite-vec": "^0.1.7-alpha.2",
		"sqlite-vec-darwin-arm64": "^0.1.7-alpha.2",
		"sqlite-vec-darwin-x64": "^0.1.7-alpha.2",
		"sqlite-vec-linux-arm64": "^0.1.7-alpha.2",
		"sqlite-vec-linux-x64": "^0.1.7-alpha.2"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.12",
		"@types/express": "^4.17.21",
		"@types/node": "^20.0.0",
		"@vitest/coverage-v8": "^2.0.0",
		"tsx": "^4.0.0",
		"typescript": "^5.0.0",
		"vitest": "^2.0.0"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
